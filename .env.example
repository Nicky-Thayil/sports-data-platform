ENVIRONMENT=development
RATE_LIMIT_PER_MINUTE=60

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sportsdata

# Database Migration
DATABASE_MIGRATION_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/sportsdata

# Redis
REDIS_URL=redis://localhost:6379

# API Key
API_KEY_SECRET=your-secret-key-here

# External API
API_FOOTBALL_KEY=your-api-football-key-here